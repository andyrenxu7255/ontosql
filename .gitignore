# ============================================================================
# OntoSQL .gitignore
# ============================================================================

# 编译产物和安装目录
build/

# 上游源码（体积过大，用户自行下载）
upstream/

# PostgreSQL 运行时数据
*.log
pg_log/

# macOS 系统文件
.DS_Store
.AppleDouble
.LSOverride
._*

# IDE 文件
.idea/
.vscode/
*.swp
*.swo
*~

# 临时文件
*.tmp
*.bak
/tmp/

# 环境变量（可能含密码）
.env
.env.local
